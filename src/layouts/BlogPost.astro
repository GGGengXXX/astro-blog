---
import { Image } from 'astro:assets';
import type { CollectionEntry } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import Header from '../components/Header.astro';

type Props = CollectionEntry<'blog'>['data'] & { entryId: string };

const { title, description, pubDate, updatedDate, heroImage, category, mood, tags, entryId } = Astro.props;
const categoryLabels = {
	note: { zh: '笔记', en: 'Notes' },
	diary: { zh: '日记', en: 'Diary' },
	idea: { zh: '想法', en: 'Ideas' },
	essay: { zh: '文章', en: 'Essays' },
};
const postText = {
	'first-post': {
		title: 'Today I set up the blog first',
		description: 'An opening diary: build the container first, then let real life move in.',
		mood: 'Starting',
		tags: ['Diary', 'Blog', 'Start'],
	},
	'second-post': {
		title: 'Astro blog maintenance checklist',
		description: 'A future note for adding posts, editing the homepage, deploying, and debugging.',
		mood: 'Clear',
		tags: ['Astro', 'GitHub Pages', 'Notes'],
	},
	'third-post': {
		title: 'Idea: write diary entries like experiments',
		description: 'A diary can record hypotheses, observations, and the next small test.',
		mood: 'Curious',
		tags: ['Writing', 'Method', 'Idea'],
	},
	'markdown-style-guide': {
		title: 'Markdown writing style notes',
		description: 'A short memo for common Markdown patterns used in this blog.',
		mood: 'Organizing',
		tags: ['Markdown', 'Writing'],
	},
	'using-mdx': {
		title: 'What MDX can be used for',
		description: 'Put small interactive pieces inside posts so the blog is more than static text.',
		mood: 'Experiment',
		tags: ['MDX', 'Interactive', 'Astro'],
	},
};
---

<html lang="zh-CN">
	<head>
		<BaseHead title={title} description={description} />
		<style>
			main {
				width: min(1120px, calc(100% - 2rem));
				max-width: 100%;
				margin: auto;
			}
			.hero-image {
				width: 100%;
			}
			.hero-image img {
				display: block;
				margin: 0 auto;
				width: 100%;
				max-height: 520px;
				object-fit: cover;
				border-radius: 8px;
				box-shadow: var(--box-shadow);
			}
			.prose {
				width: min(760px, 100%);
				margin: -3rem auto 0;
				padding: clamp(1.2rem, 3vw, 2.2rem);
				color: var(--panel-text);
				position: relative;
			}
			.title {
				margin-bottom: 1.4em;
				text-align: left;
			}
			.title h1 {
				margin: 0 0 0.45em;
				font-size: clamp(2.7rem, 7vw, 5.6rem);
			}
			.date {
				margin-bottom: 1rem;
				color: var(--muted);
			}
			.last-updated-on {
				font-style: italic;
			}
			.meta-line {
				display: flex;
				flex-wrap: wrap;
				gap: 0.45rem;
				margin-bottom: 1.25rem;
			}
			.prose :global(h2) {
				margin-top: 2rem;
				font-size: 2rem;
			}
		</style>
	</head>

	<body>
		<Header />
		<main>
			<article>
				<div class="hero-image">
					{heroImage && <Image width={1020} height={510} src={heroImage} alt="" />}
				</div>
				<div class="prose surface">
					<div class="title">
						<div class="date">
							<FormattedDate date={pubDate} />
							{
								updatedDate && (
									<div class="last-updated-on">
										<span data-locale="zh">更新于</span><span data-locale="en">Last updated on</span> <FormattedDate date={updatedDate} />
									</div>
								)
							}
						</div>
						<h1><span data-locale="zh">{title}</span><span data-locale="en">{postText[entryId]?.title ?? title}</span></h1>
						<p><span data-locale="zh">{description}</span><span data-locale="en">{postText[entryId]?.description ?? description}</span></p>
						<div class="meta-line">
							<span class="pill"><span data-locale="zh">{categoryLabels[category].zh}</span><span data-locale="en">{categoryLabels[category].en}</span></span>
							{mood && <span class="pill"><span data-locale="zh">{mood}</span><span data-locale="en">{postText[entryId]?.mood ?? mood}</span></span>}
							{tags.map((tag, index) => <span class="pill"><span data-locale="zh">{tag}</span><span data-locale="en">{postText[entryId]?.tags?.[index] ?? tag}</span></span>)}
						</div>
					</div>
					<slot />
				</div>
			</article>
		</main>
		<Footer />
	</body>
</html>
