---
import { getCollection } from 'astro:content';
import BaseHead from '../../components/BaseHead.astro';
import Footer from '../../components/Footer.astro';
import FormattedDate from '../../components/FormattedDate.astro';
import Header from '../../components/Header.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../../consts';

const posts = (await getCollection('blog')).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const categoryLabels = {
	note: '笔记',
	diary: '日记',
	idea: '想法',
	essay: '文章',
};
---

<!doctype html>
<html lang="zh-CN">
	<head>
		<BaseHead title={`归档 | ${SITE_TITLE}`} description={SITE_DESCRIPTION} />
		<style>
			.archive-head {
				display: grid;
				grid-template-columns: minmax(0, 1fr) 280px;
				gap: 1rem;
				margin-bottom: 1rem;
			}

			.archive-title {
				padding: clamp(1.25rem, 3vw, 2rem);
			}

			.archive-title p {
				max-width: 680px;
				color: var(--muted);
				font-size: 1.08rem;
			}

			.archive-stat {
				display: flex;
				flex-direction: column;
				justify-content: end;
				padding: 1.25rem;
				background: var(--ink);
				color: var(--paper);
			}

			.archive-stat strong {
				font-size: 4rem;
				line-height: 0.95;
			}

			.timeline {
				display: grid;
				gap: 0.75rem;
				margin-top: 1rem;
			}

			.archive-row {
				display: grid;
				grid-template-columns: 132px minmax(0, 1fr) auto;
				gap: 1rem;
				align-items: center;
				padding: 1rem;
				text-decoration: none;
				transition:
					transform 0.2s ease,
					border-color 0.2s ease,
					box-shadow 0.2s ease;
			}

			.archive-row:hover {
				transform: translateX(4px);
				border-color: rgba(201, 52, 47, 0.38);
				box-shadow: var(--soft-shadow);
			}

			.archive-date {
				color: var(--muted);
				font-size: 0.88rem;
			}

			.archive-row h2 {
				margin: 0 0 0.25rem;
				color: var(--ink);
				font-size: clamp(1.35rem, 3vw, 2.35rem);
			}

			.archive-row p {
				margin: 0;
				color: #48443b;
			}

			.archive-kind {
				color: var(--red);
				font-size: 0.86rem;
				font-weight: 700;
				white-space: nowrap;
			}

			@media (max-width: 760px) {
				.archive-head,
				.archive-row {
					grid-template-columns: 1fr;
				}
			}
		</style>
	</head>
	<body>
		<Header />
		<main>
			<section class="archive-head">
				<div class="archive-title surface">
					<div class="eyebrow">Archive</div>
					<h1>归档</h1>
					<p>所有笔记、日记、想法和长一点的文章都会在这里排成时间线。它不需要一开始就完整，重要的是能持续加入。</p>
				</div>
				<div class="archive-stat surface">
					<strong>{posts.length}</strong>
					<span>entries saved</span>
				</div>
			</section>

			<section class="timeline">
				{
					posts.map((post) => (
						<a class="archive-row surface" href={`${base}/blog/${post.id}/`}>
							<div class="archive-date">
								<FormattedDate date={post.data.pubDate} />
							</div>
							<div>
								<h2>{post.data.title}</h2>
								<p>{post.data.description}</p>
								<div class="tag-row">
									{post.data.tags.map((tag) => (
										<span class="pill">{tag}</span>
									))}
								</div>
							</div>
							<div class="archive-kind">{categoryLabels[post.data.category]}</div>
						</a>
					))
				}
			</section>
		</main>
		<Footer />
	</body>
</html>
