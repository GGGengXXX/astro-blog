---
import { getCollection } from 'astro:content';
import BaseHead from '../../components/BaseHead.astro';
import Footer from '../../components/Footer.astro';
import FormattedDate from '../../components/FormattedDate.astro';
import Header from '../../components/Header.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../../consts';

const posts = (await getCollection('blog')).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const categoryLabels = {
	note: { zh: '笔记', en: 'Notes' },
	diary: { zh: '日记', en: 'Diary' },
	idea: { zh: '想法', en: 'Ideas' },
	essay: { zh: '文章', en: 'Essays' },
};
const postText = {
	'first-post': {
		title: 'Today I set up the blog first',
		description: 'An opening diary: build the container first, then let real life move in.',
		tags: ['Diary', 'Blog', 'Start'],
	},
	'second-post': {
		title: 'Astro blog maintenance checklist',
		description: 'A future note for adding posts, editing the homepage, deploying, and debugging.',
		tags: ['Astro', 'GitHub Pages', 'Notes'],
	},
	'third-post': {
		title: 'Idea: write diary entries like experiments',
		description: 'A diary can record hypotheses, observations, and the next small test.',
		tags: ['Writing', 'Method', 'Idea'],
	},
	'markdown-style-guide': {
		title: 'Markdown writing style notes',
		description: 'A short memo for common Markdown patterns used in this blog.',
		tags: ['Markdown', 'Writing'],
	},
	'using-mdx': {
		title: 'What MDX can be used for',
		description: 'Put small interactive pieces inside posts so the blog is more than static text.',
		tags: ['MDX', 'Interactive', 'Astro'],
	},
};
---

<!doctype html>
<html lang="zh-CN">
	<head>
		<BaseHead title={`归档 | ${SITE_TITLE}`} description={SITE_DESCRIPTION} />
		<style>
			.archive-head {
				display: grid;
				grid-template-columns: minmax(0, 1fr) 280px;
				gap: 1rem;
				margin-bottom: 1rem;
			}

			.archive-title {
				padding: clamp(1.25rem, 3vw, 2rem);
			}

			.archive-title p {
				max-width: 680px;
				color: var(--muted);
				font-size: 1.08rem;
			}

			.archive-stat {
				display: flex;
				flex-direction: column;
				justify-content: end;
				padding: 1.25rem;
				background: var(--inverse);
				color: var(--inverse-text);
			}

			.archive-stat strong {
				font-size: 4rem;
				line-height: 0.95;
			}

			.timeline {
				display: grid;
				gap: 0.75rem;
				margin-top: 1rem;
			}

			.archive-row {
				display: grid;
				grid-template-columns: 132px minmax(0, 1fr) auto;
				gap: 1rem;
				align-items: center;
				padding: 1rem;
				text-decoration: none;
				transition:
					transform 0.2s ease,
					border-color 0.2s ease,
					box-shadow 0.2s ease;
			}

			.archive-row:hover {
				transform: translateX(4px);
				border-color: rgba(201, 52, 47, 0.38);
				box-shadow: var(--soft-shadow);
			}

			.archive-date {
				color: var(--muted);
				font-size: 0.88rem;
			}

			.archive-row h2 {
				margin: 0 0 0.25rem;
				color: var(--ink);
				font-size: clamp(1.35rem, 3vw, 2.35rem);
			}

			.archive-row p {
				margin: 0;
				color: var(--panel-text);
			}

			.archive-kind {
				color: var(--red);
				font-size: 0.86rem;
				font-weight: 700;
				white-space: nowrap;
			}

			@media (max-width: 760px) {
				.archive-head,
				.archive-row {
					grid-template-columns: 1fr;
				}
			}
		</style>
	</head>
	<body>
		<Header />
		<main>
			<section class="archive-head">
				<div class="archive-title surface">
					<div class="eyebrow">Archive</div>
					<h1><span data-locale="zh">归档</span><span data-locale="en">Archive</span></h1>
					<p>
						<span data-locale="zh">所有笔记、日记、想法和长一点的文章都会在这里排成时间线。它不需要一开始就完整，重要的是能持续加入。</span>
						<span data-locale="en">All notes, diary fragments, ideas, and longer essays are arranged here as a timeline. It does not need to be complete at first; it only needs to keep accepting new entries.</span>
					</p>
				</div>
				<div class="archive-stat surface">
					<strong>{posts.length}</strong>
					<span><span data-locale="zh">条已保存</span><span data-locale="en">entries saved</span></span>
				</div>
			</section>

			<section class="timeline">
				{
					posts.map((post) => (
						<a class="archive-row surface" href={`${base}/blog/${post.id}/`}>
							<div class="archive-date">
								<FormattedDate date={post.data.pubDate} />
							</div>
							<div>
								<h2><span data-locale="zh">{post.data.title}</span><span data-locale="en">{postText[post.id]?.title ?? post.data.title}</span></h2>
								<p><span data-locale="zh">{post.data.description}</span><span data-locale="en">{postText[post.id]?.description ?? post.data.description}</span></p>
								<div class="tag-row">
									{post.data.tags.map((tag, index) => (
										<span class="pill"><span data-locale="zh">{tag}</span><span data-locale="en">{postText[post.id]?.tags?.[index] ?? tag}</span></span>
									))}
								</div>
							</div>
							<div class="archive-kind">
								<span data-locale="zh">{categoryLabels[post.data.category].zh}</span>
								<span data-locale="en">{categoryLabels[post.data.category].en}</span>
							</div>
						</a>
					))
				}
			</section>
		</main>
		<Footer />
	</body>
</html>
