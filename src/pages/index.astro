---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';
---

<!doctype html>
<html lang="zh-CN">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
	</head>
	<body>
		<Header />
		<main>
			<h1>GGGengXXX Blog</h1>
			<p>
				一个基于 <a href="https://astro.build/">Astro</a> 的个人博客，用来记录想法、技术笔记和正在进行的实验。
			</p>
			<p>
				你可以直接在 <code>src/content/blog/</code> 里新增 Markdown 或 MDX 文件来发布文章。
			</p>
			<p>下一步可以从这里开始：</p>
			<ul>
				<li>修改 <code>src/pages/about.astro</code>，写一版个人介绍</li>
				<li>替换 <code>src/content/blog/</code> 里的示例文章</li>
				<li>调整 <code>src/styles/global.css</code>，换成自己的视觉风格</li>
			</ul>
		</main>
		<Footer />
	</body>
</html>
