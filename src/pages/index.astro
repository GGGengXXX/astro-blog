---
import { Image } from 'astro:assets';
import { getCollection } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import Header from '../components/Header.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';

const posts = (await getCollection('blog')).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);
const featured = posts.find((post) => post.data.featured) ?? posts[0];
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const categoryLabels = {
	all: { zh: '全部', en: 'All' },
	note: { zh: '笔记', en: 'Notes' },
	diary: { zh: '日记', en: 'Diary' },
	idea: { zh: '想法', en: 'Ideas' },
	essay: { zh: '文章', en: 'Essays' },
};
const postText = {
	'first-post': {
		title: 'Today I set up the blog first',
		description: 'An opening diary: build the container first, then let real life move in.',
		mood: 'Starting',
		tags: ['Diary', 'Blog', 'Start'],
	},
	'second-post': {
		title: 'Astro blog maintenance checklist',
		description: 'A future note for adding posts, editing the homepage, deploying, and debugging.',
		mood: 'Clear',
		tags: ['Astro', 'GitHub Pages', 'Notes'],
	},
	'third-post': {
		title: 'Idea: write diary entries like experiments',
		description: 'A diary can record hypotheses, observations, and the next small test.',
		mood: 'Curious',
		tags: ['Writing', 'Method', 'Idea'],
	},
	'markdown-style-guide': {
		title: 'Markdown writing style notes',
		description: 'A short memo for common Markdown patterns used in this blog.',
		mood: 'Organizing',
		tags: ['Markdown', 'Writing'],
	},
	'using-mdx': {
		title: 'What MDX can be used for',
		description: 'Put small interactive pieces inside posts so the blog is more than static text.',
		mood: 'Experiment',
		tags: ['MDX', 'Interactive', 'Astro'],
	},
};
---

<!doctype html>
<html lang="zh-CN">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
		<style>
			.hero {
				display: grid;
				grid-template-columns: minmax(0, 1.16fr) minmax(320px, 0.84fr);
				gap: 1rem;
				align-items: stretch;
				min-height: 560px;
			}

			.hero-copy,
			.control-panel {
				padding: clamp(1.3rem, 3vw, 2rem);
			}

			.hero-copy {
				display: flex;
				flex-direction: column;
				justify-content: space-between;
				background:
					linear-gradient(135deg, var(--panel-strong), var(--panel)),
					linear-gradient(90deg, rgba(201, 52, 47, 0.1), transparent);
				border: 1px solid var(--line);
				border-radius: 8px;
				box-shadow: var(--shadow);
			}

			.hero h1 {
				max-width: 8.6ch;
				margin-bottom: 1.2rem;
			}

			.hero-lead {
				max-width: 690px;
				color: var(--panel-text);
				font-size: clamp(1.05rem, 2vw, 1.35rem);
			}

			.hero-meta {
				display: grid;
				grid-template-columns: repeat(3, 1fr);
				gap: 0.7rem;
				margin-top: 2rem;
			}

			.metric {
				padding: 0.9rem;
				border: 1px solid var(--line);
				border-radius: 6px;
				background: var(--panel);
			}

			.metric strong {
				display: block;
				font-size: 1.65rem;
				line-height: 1;
			}

			.metric span {
				color: var(--muted);
				font-size: 0.82rem;
			}

			.control-panel {
				display: flex;
				flex-direction: column;
				justify-content: space-between;
				background: var(--inverse);
				border-radius: 8px;
				color: var(--inverse-text);
				box-shadow: var(--shadow);
			}

			.panel-kicker {
				color: var(--inverse-muted);
				font-size: 0.78rem;
				font-weight: 700;
				letter-spacing: 0.14em;
				text-transform: uppercase;
			}

			.prompt {
				margin: 1.5rem 0;
				color: var(--inverse-text);
				font-size: clamp(1.35rem, 3vw, 2.25rem);
				line-height: 1.12;
			}

			.prompt-button {
				width: 100%;
				padding: 0.9rem 1rem;
				border: 1px solid rgba(250, 248, 241, 0.22);
				border-radius: 6px;
				background: var(--red);
				color: white;
				cursor: pointer;
				font: inherit;
				transition:
					transform 0.2s ease,
					background 0.2s ease;
			}

			.prompt-button:hover {
				background: #e04a44;
				transform: translateY(-2px);
			}

			.featured {
				display: grid;
				grid-template-columns: 0.75fr 1.25fr;
				gap: 1rem;
				margin-top: 1rem;
				overflow: hidden;
			}

			.featured-image img {
				width: 100%;
				height: 100%;
				min-height: 320px;
				object-fit: cover;
				border-radius: 8px 0 0 8px;
			}

			.featured-body {
				padding: clamp(1.2rem, 3vw, 2rem);
			}

			.featured h2 {
				font-size: clamp(2rem, 4vw, 4.4rem);
			}

			.filters {
				position: sticky;
				top: 69px;
				z-index: 6;
				display: flex;
				flex-wrap: wrap;
				gap: 0.5rem;
				margin: 1rem 0;
				padding: 0.7rem;
				background: var(--panel-strong);
				border: 1px solid var(--line);
				border-radius: 8px;
				backdrop-filter: blur(16px);
			}

			.filter-button {
				padding: 0.55rem 0.86rem;
				border: 1px solid var(--line);
				border-radius: 999px;
				background: transparent;
				color: var(--ink);
				cursor: pointer;
				font: inherit;
				font-size: 0.9rem;
			}

			.filter-button[aria-pressed='true'] {
				background: var(--ink);
				color: var(--inverse-text);
			}

			.garden-grid {
				display: grid;
				grid-template-columns: repeat(12, 1fr);
				gap: 1rem;
			}

			.entry-card {
				grid-column: span 4;
				display: flex;
				flex-direction: column;
				min-height: 280px;
				padding: 1rem;
				text-decoration: none;
				transition:
					transform 0.2s ease,
					box-shadow 0.2s ease,
					border-color 0.2s ease;
			}

			.entry-card:hover {
				transform: translateY(-4px);
				border-color: rgba(201, 52, 47, 0.42);
				box-shadow: var(--shadow);
			}

			.entry-card.is-hidden {
				display: none;
			}

			.entry-top {
				display: flex;
				justify-content: space-between;
				gap: 1rem;
				margin-bottom: 1rem;
				color: var(--muted);
				font-size: 0.86rem;
			}

			.entry-card h3 {
				margin-bottom: 0.8rem;
				color: var(--ink);
			}

			.entry-card p {
				color: var(--panel-text);
			}

			.entry-card .tag-row {
				margin-top: auto;
			}

			.diary-strip {
				display: grid;
				grid-template-columns: 0.85fr 1.15fr;
				gap: 1rem;
				margin-top: 1rem;
			}

			.diary-card {
				padding: 1.25rem;
			}

			.diary-card summary {
				cursor: pointer;
				color: var(--red);
				font-weight: 700;
			}

			.mood-board {
				display: grid;
				grid-template-columns: repeat(2, 1fr);
				gap: 0.7rem;
				padding: 1.25rem;
				background: var(--inverse);
				color: var(--inverse-text);
			}

			.mood-item {
				padding: 0.8rem;
				border: 1px solid var(--line);
				border-radius: 6px;
			}

			.mood-item span {
				display: block;
				color: var(--inverse-muted);
				font-size: 0.78rem;
			}

			@media (max-width: 920px) {
				.hero,
				.featured,
				.diary-strip {
					grid-template-columns: 1fr;
				}

				.featured-image img {
					border-radius: 8px 8px 0 0;
				}

				.entry-card {
					grid-column: span 6;
				}
			}

			@media (max-width: 640px) {
				.hero {
					min-height: auto;
				}

				.hero-copy,
				.control-panel {
					padding: 1rem;
				}

				.hero h1 {
					font-size: 3.1rem;
				}

				.hero-meta,
				.mood-board {
					grid-template-columns: 1fr;
				}

				.entry-card {
					grid-column: 1 / -1;
				}

				.filters {
					top: 59px;
				}
			}
		</style>
	</head>
	<body>
		<Header />
		<main>
			<section class="hero">
				<div class="hero-copy">
					<div>
						<div class="eyebrow">Personal Garden</div>
						<h1>
							<span data-locale="zh">笔记、日记和想法的工作台</span>
							<span data-locale="en">A desk for notes, diary, and ideas</span>
						</h1>
						<p class="hero-lead">
							<span data-locale="zh">这里不是一个要一次写完的博客，而是一块可以持续整理的地方。短笔记先放下，日记先留下，想法先不用急着成熟。</span>
							<span data-locale="en">This is not a blog that needs to be finished in one pass. It is a place to keep sorting: short notes can land, diary fragments can stay, ideas do not have to mature immediately.</span>
						</p>
					</div>
					<div class="hero-meta">
						<div class="metric">
							<strong>{posts.length}</strong>
							<span><span data-locale="zh">篇记录</span><span data-locale="en">entries</span></span>
						</div>
						<div class="metric">
							<strong>{posts.filter((post) => post.data.category === 'diary').length}</strong>
							<span><span data-locale="zh">篇日记</span><span data-locale="en">diary notes</span></span>
						</div>
						<div class="metric">
							<strong>{new Set(posts.flatMap((post) => post.data.tags)).size}</strong>
							<span><span data-locale="zh">个标签</span><span data-locale="en">tags</span></span>
						</div>
					</div>
				</div>

				<aside class="control-panel">
					<div>
						<div class="panel-kicker">Today's Prompt</div>
						<p class="prompt" id="promptText">
							<span data-locale="zh">今天最值得留下来的一个细节是什么？</span>
							<span data-locale="en">What detail from today is most worth keeping?</span>
						</p>
					</div>
					<button class="prompt-button" id="promptButton" type="button">
						<span data-locale="zh">换一个写作提示</span>
						<span data-locale="en">New writing prompt</span>
					</button>
				</aside>
			</section>

			{
				featured && (
					<section class="featured surface">
						<div class="featured-image">
							{featured.data.heroImage && (
								<Image width={760} height={720} src={featured.data.heroImage} alt="" />
							)}
						</div>
						<div class="featured-body">
							<div class="eyebrow">Featured</div>
							<h2>
								<span data-locale="zh">{featured.data.title}</span>
								<span data-locale="en">{postText[featured.id]?.title ?? featured.data.title}</span>
							</h2>
							<p>
								<span data-locale="zh">{featured.data.description}</span>
								<span data-locale="en">{postText[featured.id]?.description ?? featured.data.description}</span>
							</p>
							<div class="tag-row">
								<span class="pill">
									<span data-locale="zh">{categoryLabels[featured.data.category].zh}</span>
									<span data-locale="en">{categoryLabels[featured.data.category].en}</span>
								</span>
								{featured.data.mood && (
									<span class="pill">
										<span data-locale="zh">{featured.data.mood}</span>
										<span data-locale="en">{postText[featured.id]?.mood ?? featured.data.mood}</span>
									</span>
								)}
								<a class="pill" href={`${base}/blog/${featured.id}/`}>
									<span data-locale="zh">打开这篇</span>
									<span data-locale="en">Open entry</span>
								</a>
							</div>
						</div>
					</section>
				)
			}

			<section aria-labelledby="garden-title">
				<div class="filters" aria-label="内容筛选">
					{
						Object.entries(categoryLabels).map(([key, label]) => (
							<button
								class="filter-button"
								type="button"
								data-filter={key}
								aria-pressed={key === 'all' ? 'true' : 'false'}
							>
								<span data-locale="zh">{label.zh}</span>
								<span data-locale="en">{label.en}</span>
							</button>
						))
					}
				</div>

				<div class="eyebrow">Recent Entries</div>
				<h2 id="garden-title">
					<span data-locale="zh">最近放进来的东西</span>
					<span data-locale="en">Recent things placed here</span>
				</h2>
				<div class="garden-grid" id="gardenGrid">
					{
						posts.map((post) => (
							<a class="entry-card surface" data-category={post.data.category} href={`${base}/blog/${post.id}/`}>
								<div class="entry-top">
									<span>
										<span data-locale="zh">{categoryLabels[post.data.category].zh}</span>
										<span data-locale="en">{categoryLabels[post.data.category].en}</span>
									</span>
									<FormattedDate date={post.data.pubDate} />
								</div>
								<h3>
									<span data-locale="zh">{post.data.title}</span>
									<span data-locale="en">{postText[post.id]?.title ?? post.data.title}</span>
								</h3>
								<p>
									<span data-locale="zh">{post.data.description}</span>
									<span data-locale="en">{postText[post.id]?.description ?? post.data.description}</span>
								</p>
								<div class="tag-row">
									{post.data.tags.slice(0, 3).map((tag, index) => (
										<span class="pill">
											<span data-locale="zh">{tag}</span>
											<span data-locale="en">{postText[post.id]?.tags?.[index] ?? tag}</span>
										</span>
									))}
								</div>
							</a>
						))
					}
				</div>
			</section>

			<section class="diary-strip">
				<details class="diary-card surface" open>
					<summary>
						<span data-locale="zh">今天可以怎么写日记</span>
						<span data-locale="en">How to write today</span>
					</summary>
					<p>
						<span data-locale="zh">不用写完整文章。只写三个点：发生了什么，我怎么理解它，明天要试什么。</span>
						<span data-locale="en">No need to write a complete essay. Just keep three points: what happened, how you understand it, and what to try tomorrow.</span>
					</p>
				</details>
				<div class="mood-board surface">
					<div class="mood-item">
						<span><span data-locale="zh">当前状态</span><span data-locale="en">Current state</span></span>
						<span data-locale="zh">整理中</span><span data-locale="en">Organizing</span>
					</div>
					<div class="mood-item">
						<span><span data-locale="zh">下一步</span><span data-locale="en">Next step</span></span>
						<span data-locale="zh">替换真实照片</span><span data-locale="en">Replace real photos</span>
					</div>
					<div class="mood-item">
						<span><span data-locale="zh">适合放入</span><span data-locale="en">Good for</span></span>
						<span data-locale="zh">读书笔记、项目复盘</span><span data-locale="en">Reading notes, project reviews</span>
					</div>
					<div class="mood-item">
						<span><span data-locale="zh">写作节奏</span><span data-locale="en">Writing rhythm</span></span>
						<span data-locale="zh">短一点也可以</span><span data-locale="en">Short is fine</span>
					</div>
				</div>
			</section>
		</main>
		<Footer />

		<script>
			const prompts = [
				{ zh: '今天最值得留下来的一个细节是什么？', en: 'What detail from today is most worth keeping?' },
				{ zh: '最近有什么问题反复出现，但还没有被认真记录？', en: 'What question keeps returning but has not been properly written down?' },
				{ zh: '如果把今天当成一个实验，结论会是什么？', en: 'If today were an experiment, what would the conclusion be?' },
				{ zh: '哪一条笔记以后可能会救你十分钟？', en: 'Which note might save you ten minutes later?' },
				{ zh: '现在最想整理的一团东西是什么？', en: 'What messy thing do you most want to sort out right now?' },
			];

			const promptText = document.querySelector('#promptText');
			const promptButton = document.querySelector('#promptButton');
			let promptIndex = 0;

			promptButton?.addEventListener('click', () => {
				promptIndex = (promptIndex + 1) % prompts.length;
				if (promptText) {
					const zh = promptText.querySelector('[data-locale="zh"]');
					const en = promptText.querySelector('[data-locale="en"]');
					if (zh) zh.textContent = prompts[promptIndex].zh;
					if (en) en.textContent = prompts[promptIndex].en;
				}
			});

			const filterButtons = document.querySelectorAll('[data-filter]');
			const cards = document.querySelectorAll('[data-category]');

			filterButtons.forEach((button) => {
				button.addEventListener('click', () => {
					const filter = button.getAttribute('data-filter');

					filterButtons.forEach((item) => {
						item.setAttribute('aria-pressed', String(item === button));
					});

					cards.forEach((card) => {
						const shouldShow = filter === 'all' || card.getAttribute('data-category') === filter;
						card.classList.toggle('is-hidden', !shouldShow);
					});
				});
			});
		</script>
	</body>
</html>
